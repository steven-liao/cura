// Cura Dark Theme
// Color definitions and styling constants

export global CuraDarkTheme {
    // Primary colors
    out property <color> background-primary: #1a1a2e;
    out property <color> background-secondary: #16213e;
    out property <color> background-tertiary: #0f3460;

    // Accent colors
    out property <color> accent-primary: #e94560;
    out property <color> accent-secondary: #ff6b6b;
    out property <color> accent-gradient-start: #e94560;
    out property <color> accent-gradient-end: #ff6b6b;

    // Text colors
    out property <color> text-primary: #ffffff;
    out property <color> text-secondary: #a0a0a0;
    out property <color> text-disabled: #606060;

    // Status colors
    out property <color> success: #4caf50;
    out property <color> success-light: #81c784;
    out property <color> warning: #ff9800;
    out property <color> warning-light: #ffb74d;
    out property <color> error: #f44336;
    out property <color> error-light: #e57373;
    out property <color> info: #2196f3;
    out property <color> info-light: #64b5f6;

    // Border colors
    out property <color> border-light: #2a2a4e;
    out property <color> border-medium: #3a3a6e;
    out property <color> border-focus: #e94560;

    // Shadows
    out property <length> shadow-radius: 8px;
    out property <color> shadow-color: #00000040;

    // Spacing
    out property <length> spacing-xs: 4px;
    out property <length> spacing-sm: 8px;
    out property <length> spacing-md: 16px;
    out property <length> spacing-lg: 24px;
    out property <length> spacing-xl: 48px;

    // Border radius
    out property <length> radius-sm: 4px;
    out property <length> radius-md: 8px;
    out property <length> radius-lg: 12px;
    out property <length> radius-xl: 16px;
    out property <length> radius-full: 9999px;

    // Typography
    out property <length> font-xs: 10px;
    out property <length> font-sm: 12px;
    out property <length> font-md: 14px;
    out property <length> font-lg: 16px;
    out property <length> font-xl: 18px;
    out property <length> font-xxl: 24px;
    out property <length> font-title: 32px;
}
