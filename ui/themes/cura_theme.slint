// Cura Theme
// Shared theme colors for the application

export global CuraTheme {
    in-out property <color> background: #1a1a2e;
    in-out property <color> background-secondary: #16213e;
    in-out property <color> primary: #0f3460;
    in-out property <color> primary-dark: #0a2540;
    in-out property <color> accent: #e94560;
    in-out property <color> text: #ffffff;
    in-out property <color> text-secondary: #a0a0a0;
    in-out property <color> success: #4caf50;
    in-out property <color> warning: #ff9800;
    in-out property <color> action: #2979ff;
    in-out property <color> error: #f44336;
    in-out property <color> error-dark: #c62828;
}
